{
  "$schema": "https://json.schemastore.org/tsconfig",
  "display": "Default",
  "compilerOptions": {
    "composite": false,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "lib": ["esnext"],
    "isolatedModules": true,
    "moduleResolution": "node",
    "noUncheckedIndexedAccess": true,
    "preserveWatchOutput": true,
    "skipLibCheck": true,
    "strict": true
  }
}
