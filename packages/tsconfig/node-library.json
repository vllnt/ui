{
  "$schema": "https://json.schemastore.org/tsconfig",
  "display": "Node Library",
  "extends": "./base.json",
  "compilerOptions": {
    "composite": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "lib": ["esnext"],
    "module": "commonjs",
    "moduleResolution": "node",
    "isolatedModules": true,
    "target": "es6"
  }
}
