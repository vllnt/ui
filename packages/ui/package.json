{
  "name": "@vllnt/ui",
  "version": "0.2.1",
  "description": "React component library — 93 components built on Radix UI, Tailwind CSS, and CVA",
  "license": "MIT",
  "author": "vllnt",
  "homepage": "https://github.com/vllnt/ui#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vllnt/ui.git",
    "directory": "packages/ui"
  },
  "bugs": {
    "url": "https://github.com/vllnt/ui/issues"
  },
  "keywords": [
    "react",
    "components",
    "ui",
    "radix-ui",
    "tailwindcss",
    "design-system",
    "shadcn"
  ],
  "type": "module",
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./tailwind-preset": {
      "types": "./src/tailwind-preset.ts",
      "import": "./src/tailwind-preset.ts"
    },
    "./styles.css": "./styles.css",
    "./themes/default.css": "./themes/default.css"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public",
    "main": "./dist/index.js",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      },
      "./tailwind-preset": {
        "types": "./dist/tailwind-preset.d.ts",
        "import": "./dist/tailwind-preset.js"
      },
      "./styles.css": "./styles.css",
      "./themes/default.css": "./themes/default.css"
    }
  },
  "files": [
    "dist",
    "styles.css",
    "themes",
    "CHANGELOG.md",
    "README.md"
  ],
  "sideEffects": [
    "*.css"
  ],
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist node_modules coverage .snapshots playwright-report test-results storybook-static",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "check:circular": "madge --circular --extensions ts,tsx src",
    "test": "vitest",
    "test:once": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:visual": "playwright test -c playwright-ct.config.ts",
    "test:visual:update": "playwright test -c playwright-ct.config.ts --update-snapshots",
    "test:all": "pnpm test:coverage && pnpm test:visual",
    "test:generate": "tsx scripts/generate-tests.ts",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "test-storybook": "test-storybook",
    "storybook:generate": "tsx scripts/generate-stories.ts",
    "storybook:generate-docs": "tsx scripts/generate-docs.ts",
    "storybook:verify": "tsx scripts/verify-stories.ts",
    "storybook:fix-stories": "tsx scripts/fix-stories.ts",
    "check:stories": "tsx scripts/check-story-coverage.ts",
    "check:use-client": "tsx scripts/check-use-client.ts"
  },
  "peerDependencies": {
    "next": ">=14.0.0",
    "next-themes": ">=0.4.0",
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0",
    "tailwindcss": ">=3.0.0"
  },
  "peerDependenciesMeta": {
    "next": {
      "optional": true
    },
    "next-themes": {
      "optional": true
    }
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@mdx-js/mdx": "^3.1.1",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-aspect-ratio": "^1.1.8",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-context-menu": "^2.2.16",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-hover-card": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-menubar": "^1.1.16",
    "@radix-ui/react-navigation-menu": "^1.2.14",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-toggle": "^1.1.10",
    "@radix-ui/react-toggle-group": "^1.1.11",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tanstack/react-table": "^8.21.3",
    "@xyflow/react": "^12.10.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.0.0",
    "embla-carousel-react": "^8.6.0",
    "html-to-image": "^1.11.13",
    "input-otp": "^1.4.2",
    "lucide-react": "^0.468.0",
    "react-day-picker": "^9.13.0",
    "react-hook-form": "^7.73.1",
    "react-markdown": "^10.1.0",
    "react-resizable-panels": "^4.3.3",
    "react-syntax-highlighter": "^16.1.1",
    "sonner": "^1.7.4",
    "tailwind-merge": "^2.5.5",
    "vaul": "^1.1.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^5.0.1",
    "@github-ui/storybook-addon-performance-panel": "^1.1.4",
    "@playwright/experimental-ct-react": "^1.57.0",
    "@storybook/addon-a11y": "^10.2.17",
    "@storybook/addon-designs": "^11.1.2",
    "@storybook/addon-docs": "^10.2.17",
    "@storybook/addon-mcp": "^0.3.4",
    "@storybook/addon-themes": "^10.2.17",
    "@storybook/react-vite": "^10.2.17",
    "@storybook/test-runner": "^0.24.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^22",
    "@types/react": "^19.1.6",
    "@types/react-dom": "^19.1.6",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@vitest/coverage-v8": "^4.0.16",
    "@vllnt/eslint-config": "^1.0.0",
    "@vllnt/typescript": "^1.0.0",
    "autoprefixer": "^10.4.21",
    "eslint": "^9.39.1",
    "jsdom": "^26.1.0",
    "playwright": "^1.57.0",
    "postcss": "^8.5.6",
    "remark-gfm": "^4.0.1",
    "storybook": "^10.2.17",
    "tailwindcss": "^3.4.17",
    "tailwindcss-animate": "^1.0.7",
    "tsup": "^8.5.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.16"
  }
}
