{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "declaration": true,
    "declarationMap": true,
    "outDir": "./dist",
    "rootDir": "./src",
    "incremental": false,
    "target": "es2020",
    "module": "esnext",
    "moduleResolution": "bundler",
    "types": ["node"]
  },
  "include": ["src"],
  "exclude": [
    "node_modules",
    "src/**/*.test.ts",
    "src/**/*.test.tsx",
    "src/**/*.visual.tsx",
    "src/**/*.stories.tsx",
    "scripts",
    "playwright",
    "vitest.config.ts",
    "playwright-ct.config.ts"
  ]
}
