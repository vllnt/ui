{
  "$schema": "./tokens.schema.json",
  "name": "VLLNT UI",
  "version": "0.3.0",
  "source": {
    "guide": "../../DESIGN.md",
    "theme": "../ui/themes/default.css"
  },
  "color": {
    "format": "hsl-channel",
    "semantic": {
      "background": {
        "cssVariable": "--background",
        "light": "0 0% 100%",
        "dark": "0 0% 0%",
        "role": "Page and app surface"
      },
      "foreground": {
        "cssVariable": "--foreground",
        "light": "0 0% 3.9%",
        "dark": "0 0% 98%",
        "role": "Primary text and icon color"
      },
      "card": {
        "cssVariable": "--card",
        "light": "0 0% 100%",
        "dark": "0 0% 3.9%",
        "role": "Card and contained surface"
      },
      "cardForeground": {
        "cssVariable": "--card-foreground",
        "light": "0 0% 3.9%",
        "dark": "0 0% 98%",
        "role": "Text on card surfaces"
      },
      "popover": {
        "cssVariable": "--popover",
        "light": "0 0% 100%",
        "dark": "0 0% 3.9%",
        "role": "Popover, menu, and floating surface"
      },
      "popoverForeground": {
        "cssVariable": "--popover-foreground",
        "light": "0 0% 3.9%",
        "dark": "0 0% 98%",
        "role": "Text on popover surfaces"
      },
      "primary": {
        "cssVariable": "--primary",
        "light": "0 0% 9%",
        "dark": "0 0% 98%",
        "role": "Primary action surface"
      },
      "primaryForeground": {
        "cssVariable": "--primary-foreground",
        "light": "0 0% 98%",
        "dark": "0 0% 9%",
        "role": "Text on primary action surfaces"
      },
      "secondary": {
        "cssVariable": "--secondary",
        "light": "0 0% 96.1%",
        "dark": "0 0% 14.9%",
        "role": "Secondary action surface"
      },
      "secondaryForeground": {
        "cssVariable": "--secondary-foreground",
        "light": "0 0% 9%",
        "dark": "0 0% 98%",
        "role": "Text on secondary action surfaces"
      },
      "muted": {
        "cssVariable": "--muted",
        "light": "0 0% 96.1%",
        "dark": "0 0% 14.9%",
        "role": "Subtle surface"
      },
      "mutedForeground": {
        "cssVariable": "--muted-foreground",
        "light": "0 0% 45.1%",
        "dark": "0 0% 63.9%",
        "role": "Secondary text"
      },
      "accent": {
        "cssVariable": "--accent",
        "light": "0 0% 96.1%",
        "dark": "0 0% 14.9%",
        "role": "Hover and active surface"
      },
      "accentForeground": {
        "cssVariable": "--accent-foreground",
        "light": "0 0% 9%",
        "dark": "0 0% 98%",
        "role": "Text on accent surfaces"
      },
      "destructive": {
        "cssVariable": "--destructive",
        "light": "0 84.2% 60.2%",
        "dark": "0 62.8% 30.6%",
        "role": "Destructive action and error surface"
      },
      "destructiveForeground": {
        "cssVariable": "--destructive-foreground",
        "light": "0 0% 98%",
        "dark": "0 0% 98%",
        "role": "Text on destructive surfaces"
      },
      "border": {
        "cssVariable": "--border",
        "light": "0 0% 89.8%",
        "dark": "0 0% 14.9%",
        "role": "Hairline divider"
      },
      "input": {
        "cssVariable": "--input",
        "light": "0 0% 89.8%",
        "dark": "0 0% 14.9%",
        "role": "Input border"
      },
      "ring": {
        "cssVariable": "--ring",
        "light": "0 0% 3.9%",
        "dark": "0 0% 83.1%",
        "role": "Focus ring"
      }
    }
  },
  "typography": {
    "fontFamily": {
      "sans": "system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif",
      "mono": "ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace"
    },
    "scale": {
      "display": {
        "fontSize": "3rem",
        "lineHeight": "1.1",
        "fontWeight": 600
      },
      "h2": {
        "fontSize": "2rem",
        "lineHeight": "1.2",
        "fontWeight": 600
      },
      "h3": {
        "fontSize": "1.5rem",
        "lineHeight": "1.25",
        "fontWeight": 600
      },
      "h4": {
        "fontSize": "1.25rem",
        "lineHeight": "1.3",
        "fontWeight": 600
      },
      "bodyLarge": {
        "fontSize": "1.125rem",
        "lineHeight": "1.6",
        "fontWeight": 400
      },
      "body": {
        "fontSize": "1rem",
        "lineHeight": "1.6",
        "fontWeight": 400
      },
      "bodySmall": {
        "fontSize": "0.875rem",
        "lineHeight": "1.5",
        "fontWeight": 400
      },
      "caption": {
        "fontSize": "0.75rem",
        "lineHeight": "1.4",
        "fontWeight": 500
      }
    }
  },
  "spacing": {
    "unit": "4px",
    "scale": {
      "1": "0.25rem",
      "2": "0.5rem",
      "3": "0.75rem",
      "4": "1rem",
      "6": "1.5rem",
      "8": "2rem",
      "12": "3rem",
      "16": "4rem"
    }
  },
  "radius": {
    "none": "0",
    "sm": "0.25rem",
    "md": "0.5rem",
    "lg": "0.75rem",
    "full": "9999px"
  },
  "elevation": {
    "none": "none",
    "sm": "0 1px 2px rgba(0, 0, 0, 0.05)",
    "md": "0 4px 6px -1px rgba(0, 0, 0, 0.1)",
    "lg": "0 10px 15px -3px rgba(0, 0, 0, 0.1)"
  },
  "motion": {
    "duration": {
      "fast": "100ms",
      "base": "200ms",
      "slow": "300ms"
    },
    "easing": {
      "enter": "ease-out",
      "exit": "ease-in",
      "layout": "ease-in-out"
    },
    "reducedMotion": "Collapse durations to 1ms or skip non-essential motion."
  },
  "iconography": {
    "library": "lucide-react",
    "size": {
      "default": "1rem",
      "compact": "0.875rem",
      "large": "1.25rem"
    },
    "strokeWidth": 2,
    "color": "currentColor"
  }
}
