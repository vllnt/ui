{
  "name": "@vllnt/ui-monorepo",
  "private": true,
  "version": "0.1.0",
  "homepage": "https://ui.vllnt.ai",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vllnt/ui.git"
  },
  "bugs": {
    "url": "https://github.com/vllnt/ui/issues"
  },
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "prepare": "git config core.hooksPath .githooks || true",
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "lint:fix": "turbo lint:fix",
    "test": "turbo test",
    "test:once": "turbo test:once",
    "clean": "turbo clean",
    "check:circular": "turbo check:circular",
    "registry:build": "turbo registry:build",
    "doctor": "npx --yes react-doctor . --offline",
    "doctor:full": "npx --yes react-doctor . --offline --full --verbose",
    "doctor:json": "npx --yes react-doctor . --offline --json > .react-doctor.json",
    "doctor:errors": "npx --yes react-doctor . --offline --fail-on error",
    "doctor:diff": "npx --yes react-doctor . --offline --diff origin/main",
    "doctor:staged": "git diff --cached --name-only --diff-filter=ACM | grep -E '\\.(tsx|jsx|ts)$' | npx --yes react-doctor . --offline --changed-files-from /dev/stdin --fail-on error",
    "doctor:score": "npx --yes react-doctor . --offline --score"
  },
  "devDependencies": {
    "turbo": "^2.4.4"
  },
  "pnpm": {
    "overrides": {
      "hono": "4.12.18",
      "@hono/node-server": "1.19.13",
      "express-rate-limit": "8.2.2",
      "axios": "1.15.2",
      "follow-redirects": "1.16.0",
      "fast-uri": "3.1.2",
      "ip-address": "10.1.1",
      "minimatch": ">=10.2.3",
      "eslint-plugin-react>minimatch": "^3.1.2",
      "ajv": ">=8.18.0",
      "@eslint/eslintrc>ajv": "^6.12.4",
      "eslint>ajv": "^6.12.4",
      "qs": ">=6.14.2",
      "rollup": ">=4.59.0",
      "next": ">=16.2.6",
      "@playwright/experimental-ct-core>vite": "6.4.2",
      "@storybook/builder-vite>vite": "7.3.2",
      "@storybook/csf-plugin>vite": "7.3.2",
      "@storybook/react-vite>vite": "7.3.2",
      "@joshwooding/vite-plugin-react-docgen-typescript>vite": "7.3.2",
      "@vitejs/plugin-react>vite": "7.3.2",
      "@vitest/mocker>vite": "7.3.2",
      "vitest>vite": "7.3.2",
      "picomatch@<2.3.2": "2.3.2",
      "picomatch@>=4.0.0 <4.0.4": "4.0.4",
      "brace-expansion@<1.1.13": "1.1.13",
      "brace-expansion@>=4.0.0 <5.0.6": "5.0.6",
      "lodash": ">=4.18.1",
      "flatted": ">=3.4.2",
      "postcss": ">=8.5.10"
    }
  }
}
